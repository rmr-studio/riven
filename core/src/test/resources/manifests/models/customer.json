  "displayName": {
    "singular": "Customer",
    "plural": "Customers"
  },
  "icon": {
    "type": "USERS",
    "colour": "BLUE"
  },
  "semanticGroup": "CUSTOMER",
  "identifierKey": "email",
  "attributes": {
    "name": {
      "key": "TEXT",
      "label": "Full Name",
      "type": "string",
      "required": true,
