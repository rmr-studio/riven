{
  "manifestVersion": "1.0",
  "key": "saas-starter",
  "name": "SaaS Starter",
  "description": "A starter template for SaaS businesses with customer management and deal tracking.",
  "entityTypes": [
    {
      "$ref": "models/customer",
      "extend": {
        "description": "A SaaS customer with subscription information.",
        "attributes": {
          "subscription-tier": {
            "key": "SELECT",
            "label": "Subscription Tier",
            "type": "string",
            "options": {
              "enum": ["free", "starter", "professional", "enterprise"]
            },
            "semantics": {
              "definition": "The customer's current subscription tier.",
              "classification": "CATEGORICAL",
              "tags": ["subscription", "billing"]
            }
          },
          "mrr": {
            "key": "CURRENCY",
            "label": "Monthly Recurring Revenue",
            "type": "number",
            "format": "currency",
            "semantics": {
              "definition": "Monthly recurring revenue from this customer.",
              "classification": "QUANTITATIVE",
              "tags": ["revenue", "billing"]
            }
          }
        },
        "semantics": {
          "tags": ["saas", "subscription"]
        }
      }
    },
    {
      "key": "deal",
      "name": "Deal",
      "description": "A sales deal or opportunity being tracked through the pipeline.",
      "displayName": {
        "singular": "Deal",
        "plural": "Deals"
      },
      "icon": {
        "type": "HANDSHAKE",
        "colour": "GREEN"
      },
      "semanticGroup": "TRANSACTION",
      "identifierKey": "title",
      "attributes": {
        "title": {
          "key": "TEXT",
          "label": "Deal Title",
          "type": "string",
          "required": true,
          "semantics": {
            "definition": "The title or name of the deal.",
            "classification": "IDENTIFIER",
            "tags": ["name"]
          }
        },
        "value": {
          "key": "CURRENCY",
          "label": "Deal Value",
          "type": "number",
          "format": "currency",
          "semantics": {
            "definition": "The monetary value of the deal.",
            "classification": "QUANTITATIVE",
            "tags": ["revenue"]
          }
        },
        "stage": {
          "key": "SELECT",
          "label": "Deal Stage",
          "type": "string",
          "options": {
            "enum": ["prospect", "qualified", "proposal", "negotiation", "closed-won", "closed-lost"]
          },
          "semantics": {
            "definition": "Current stage of the deal in the sales pipeline.",
            "classification": "CATEGORICAL",
            "tags": ["pipeline", "status"]
          }
        },
        "close-date": {
          "key": "DATE",
          "label": "Expected Close Date",
          "type": "string",
          "format": "date",
          "semantics": {
            "definition": "Expected date when the deal will close.",
            "classification": "TEMPORAL",
            "tags": ["timeline"]
          }
        }
      },
      "semantics": {
        "definition": "Represents a sales deal or opportunity. Tracks the progression from prospect to close.",
        "tags": ["sales", "pipeline"]
      }
    }
  ],
  "relationships": [
    {
      "key": "customer-deals",
      "sourceEntityTypeKey": "customer",
      "name": "Deals",
      "cardinality": "ONE_TO_MANY",
      "targetEntityTypeKey": "deal",
      "semantics": {
        "definition": "Links a customer to their associated deals.",
        "tags": ["sales"]
      }
    },
    {
      "key": "deal-customer",
      "sourceEntityTypeKey": "deal",
      "name": "Customer",
      "icon": {
        "type": "USER",
        "colour": "BLUE"
      },
      "targetRules": [
        {
          "targetEntityTypeKey": "customer",
          "cardinalityOverride": "MANY_TO_ONE",
          "inverseVisible": true,
          "inverseName": "Deals"
        }
      ],
      "semantics": {
        "definition": "Links a deal back to the owning customer.",
        "tags": ["sales"]
      }
    }
  ]
}
