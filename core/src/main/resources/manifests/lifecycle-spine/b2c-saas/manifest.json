{
  "manifestVersion": "1.0",
  "key": "b2c-saas",
  "name": "B2C SaaS",
  "description": "Lifecycle template for B2C and prosumer SaaS businesses. Traces the full customer journey from acquisition through subscription, feature usage, support, and billing to retention or churn.",
  "entityTypes": [
    { "$ref": "models/customer" },
    { "$ref": "models/communication" },
    { "$ref": "models/support-ticket" },
    {
      "key": "subscription",
      "displayName": { "singular": "Subscription", "plural": "Subscriptions" },
      "semanticGroup": "TRANSACTION",
      "lifecycleDomain": "BILLING",
      "identifierKey": "plan-name",
      "icon": { "type": "REPEAT", "colour": "EMERALD" },
      "attributes": {
        "plan-name": {
          "key": "TEXT",
          "label": "Plan",
          "type": "string",
          "semantics": {
            "definition": "Name of the subscription plan.",
            "classification": "IDENTIFIER",
            "tags": ["display-name", "plan"]
          }
        },
        "status": {
          "key": "SELECT",
          "label": "Status",
          "type": "string",
          "options": {
            "enum": ["trialing", "active", "past-due", "cancelled", "paused"],
            "default": "trialing"
          },
          "semantics": {
            "definition": "Current subscription status.",
            "classification": "CATEGORICAL",
            "tags": ["lifecycle", "billing"]
          }
        },
        "mrr": {
          "key": "CURRENCY",
          "label": "MRR",
          "type": "number",
          "format": "currency",
          "semantics": {
            "definition": "Monthly recurring revenue from this subscription.",
            "classification": "QUANTITATIVE",
            "tags": ["revenue", "metrics"]
          }
        },
        "billing-interval": {
          "key": "SELECT",
          "label": "Billing Interval",
          "type": "string",
          "options": {
            "enum": ["monthly", "quarterly", "annual"]
          },
          "semantics": {
            "definition": "How frequently the subscription is billed.",
            "classification": "CATEGORICAL",
            "tags": ["billing", "plan"]
          }
        },
        "start-date": {
          "key": "DATE",
          "label": "Start Date",
          "type": "string",
          "format": "date",
          "semantics": {
            "definition": "Date the subscription started.",
            "classification": "TEMPORAL",
            "tags": ["timeline", "onboarding"]
          }
        },
        "cancel-date": {
          "key": "DATE",
          "label": "Cancel Date",
          "type": "string",
          "format": "date",
          "semantics": {
            "definition": "Date the subscription was cancelled, if applicable.",
            "classification": "TEMPORAL",
            "tags": ["timeline", "churn"]
          }
        }
      },
      "semantics": {
        "definition": "A recurring subscription plan held by a customer. The core revenue relationship in a SaaS business.",
        "tags": ["subscription", "recurring-revenue", "saas", "billing"]
      }
    },
    {
      "key": "feature-usage-event",
      "displayName": { "singular": "Feature Usage Event", "plural": "Feature Usage Events" },
      "semanticGroup": "OPERATIONAL",
      "lifecycleDomain": "USAGE",
      "identifierKey": "feature-name",
      "icon": { "type": "ACTIVITY", "colour": "CYAN" },
      "attributes": {
        "feature-name": {
          "key": "TEXT",
          "label": "Feature",
          "type": "string",
          "semantics": {
            "definition": "Name of the feature that was used.",
            "classification": "IDENTIFIER",
            "tags": ["display-name", "feature"]
          }
        },
        "action": {
          "key": "SELECT",
          "label": "Action",
          "type": "string",
          "options": {
            "enum": ["viewed", "used", "completed", "error"]
          },
          "semantics": {
            "definition": "What the user did with the feature.",
            "classification": "CATEGORICAL",
            "tags": ["event-type", "engagement"]
          }
        },
        "date": {
          "key": "DATE",
          "label": "Date",
          "type": "string",
          "format": "date",
          "semantics": {
            "definition": "When the usage event occurred.",
            "classification": "TEMPORAL",
            "tags": ["timeline", "activity"]
          }
        },
        "count": {
          "key": "NUMBER",
          "label": "Count",
          "type": "number",
          "semantics": {
            "definition": "Number of times this action was performed in this event.",
            "classification": "QUANTITATIVE",
            "tags": ["engagement", "frequency"]
          }
        }
      },
      "semantics": {
        "definition": "Records product feature usage by a customer. Used for activation analysis, feature adoption tracking, and engagement scoring.",
        "tags": ["product-analytics", "engagement", "activation"]
      }
    },
    {
      "key": "acquisition-source",
      "displayName": { "singular": "Acquisition Source", "plural": "Acquisition Sources" },
      "semanticGroup": "OPERATIONAL",
      "lifecycleDomain": "ACQUISITION",
      "identifierKey": "name",
      "icon": { "type": "MEGAPHONE", "colour": "VIOLET" },
      "attributes": {
        "name": {
          "key": "TEXT",
          "label": "Name",
          "type": "string",
          "semantics": {
            "definition": "Name of the acquisition channel or campaign.",
            "classification": "IDENTIFIER",
            "tags": ["display-name", "marketing"]
          }
        },
        "type": {
          "key": "SELECT",
          "label": "Type",
          "type": "string",
          "options": {
            "enum": ["paid-search", "paid-social", "organic", "email", "referral", "affiliate", "direct", "product-hunt", "content"]
          },
          "semantics": {
            "definition": "Category of acquisition channel.",
            "classification": "CATEGORICAL",
            "tags": ["marketing", "channel-type"]
          }
        },
        "spend": {
          "key": "CURRENCY",
          "label": "Spend",
          "type": "number",
          "format": "currency",
          "semantics": {
            "definition": "Total spend on this channel or campaign.",
            "classification": "QUANTITATIVE",
            "tags": ["marketing-spend", "budget"]
          }
        },
        "active": {
          "key": "CHECKBOX",
          "label": "Active",
          "type": "boolean",
          "semantics": {
            "definition": "Whether this channel or campaign is currently running.",
            "classification": "CATEGORICAL",
            "tags": ["status"]
          }
        }
      },
      "semantics": {
        "definition": "A marketing channel or campaign that brings users to the product. Used for attribution and channel quality analysis.",
        "tags": ["marketing", "acquisition", "attribution"]
      }
    },
    {
      "key": "billing-event",
      "displayName": { "singular": "Billing Event", "plural": "Billing Events" },
      "semanticGroup": "FINANCIAL",
      "lifecycleDomain": "BILLING",
      "identifierKey": "description",
      "icon": { "type": "CREDIT_CARD", "colour": "EMERALD" },
      "attributes": {
        "description": {
          "key": "TEXT",
          "label": "Description",
          "type": "string",
          "semantics": {
            "definition": "Description of the billing event.",
            "classification": "IDENTIFIER",
            "tags": ["display-name"]
          }
        },
        "type": {
          "key": "SELECT",
          "label": "Type",
          "type": "string",
          "options": {
            "enum": ["charge", "refund", "credit", "adjustment", "payout", "trial-start", "trial-end"]
          },
          "semantics": {
            "definition": "The type of billing event.",
            "classification": "CATEGORICAL",
            "tags": ["billing", "classification"]
          }
        },
        "amount": {
          "key": "CURRENCY",
          "label": "Amount",
          "type": "number",
          "format": "currency",
          "semantics": {
            "definition": "Monetary value of this billing event.",
            "classification": "QUANTITATIVE",
            "tags": ["financial", "revenue"]
          }
        },
        "date": {
          "key": "DATE",
          "label": "Date",
          "type": "string",
          "format": "date",
          "semantics": {
            "definition": "Date the billing event occurred.",
            "classification": "TEMPORAL",
            "tags": ["timeline", "billing"]
          }
        }
      },
      "semantics": {
        "definition": "A financial event in the subscription lifecycle — charges, refunds, credits, trial events, or adjustments.",
        "tags": ["billing", "finance", "revenue", "subscription"]
      }
    },
    {
      "key": "churn-event",
      "displayName": { "singular": "Churn Event", "plural": "Churn Events" },
      "semanticGroup": "FINANCIAL",
      "lifecycleDomain": "RETENTION",
      "identifierKey": "reason",
      "icon": { "type": "USER_MINUS", "colour": "ROSE" },
      "attributes": {
        "reason": {
          "key": "SELECT",
          "label": "Reason",
          "type": "string",
          "options": {
            "enum": ["price", "competitor", "no-longer-needed", "poor-experience", "missing-feature", "onboarding-failure", "unknown"]
          },
          "semantics": {
            "definition": "The stated or inferred reason for churning.",
            "classification": "CATEGORICAL",
            "tags": ["churn-reason", "analysis"]
          }
        },
        "date": {
          "key": "DATE",
          "label": "Date",
          "type": "string",
          "format": "date",
          "required": true,
          "semantics": {
            "definition": "Date the churn event occurred.",
            "classification": "TEMPORAL",
            "tags": ["timeline", "churn"]
          }
        },
        "type": {
          "key": "SELECT",
          "label": "Type",
          "type": "string",
          "options": {
            "enum": ["voluntary", "involuntary"],
            "default": "voluntary"
          },
          "semantics": {
            "definition": "Whether the customer chose to cancel (voluntary) or was lost due to payment failure etc. (involuntary).",
            "classification": "CATEGORICAL",
            "tags": ["churn-type", "classification"]
          }
        },
        "mrr-lost": {
          "key": "CURRENCY",
          "label": "MRR Lost",
          "type": "number",
          "format": "currency",
          "semantics": {
            "definition": "Monthly recurring revenue lost from this churn event.",
            "classification": "QUANTITATIVE",
            "tags": ["revenue-impact", "financial"]
          }
        },
        "notes": {
          "key": "TEXT",
          "label": "Notes",
          "type": "string",
          "semantics": {
            "definition": "Additional context about the churn event.",
            "classification": "FREETEXT",
            "tags": ["context"]
          }
        }
      },
      "semantics": {
        "definition": "Records when and why a subscription ended. The terminal lifecycle event for SaaS, with MRR impact tracking.",
        "tags": ["churn", "retention", "lifecycle", "revenue"]
      }
    }
  ],
  "relationships": [
    {
      "key": "customer-subscriptions",
      "sourceEntityTypeKey": "customer",
      "name": "Subscriptions",
      "protected": true,
      "targetRules": [
        { "targetEntityTypeKey": "subscription", "cardinalityOverride": "ONE_TO_MANY", "inverseName": "Customer" }
      ],
      "semantics": {
        "definition": "A customer holds one or more subscriptions to the product.",
        "tags": ["subscription", "billing"]
      }
    },
    {
      "key": "customer-support-tickets",
      "sourceEntityTypeKey": "customer",
      "name": "Support Tickets",
      "protected": true,
      "targetRules": [
        { "targetEntityTypeKey": "support-ticket", "cardinalityOverride": "ONE_TO_MANY", "inverseName": "Customer" }
      ],
      "semantics": {
        "definition": "A customer files support tickets for issues or questions.",
        "tags": ["support", "service"]
      }
    },
    {
      "key": "customer-acquisition-source",
      "sourceEntityTypeKey": "customer",
      "name": "Acquisition Source",
      "protected": true,
      "targetRules": [
        { "targetEntityTypeKey": "acquisition-source", "cardinalityOverride": "MANY_TO_ONE", "inverseName": "Customers" }
      ],
      "semantics": {
        "definition": "The acquisition channel through which the customer signed up.",
        "tags": ["attribution", "marketing"]
      }
    },
    {
      "key": "customer-billing-events",
      "sourceEntityTypeKey": "customer",
      "name": "Billing Events",
      "protected": true,
      "targetRules": [
        { "targetEntityTypeKey": "billing-event", "cardinalityOverride": "ONE_TO_MANY", "inverseName": "Customer" }
      ],
      "semantics": {
        "definition": "Billing events associated with a customer's account.",
        "tags": ["billing", "financial"]
      }
    },
    {
      "key": "customer-churn-events",
      "sourceEntityTypeKey": "customer",
      "name": "Churn Events",
      "protected": true,
      "targetRules": [
        { "targetEntityTypeKey": "churn-event", "cardinalityOverride": "ONE_TO_MANY", "inverseName": "Customer" }
      ],
      "semantics": {
        "definition": "Churn events marking the end of a customer relationship.",
        "tags": ["churn", "retention"]
      }
    },
    {
      "key": "customer-communications",
      "sourceEntityTypeKey": "customer",
      "name": "Communications",
      "protected": true,
      "targetRules": [
        { "targetEntityTypeKey": "communication", "cardinalityOverride": "ONE_TO_MANY", "inverseName": "Customer" }
      ],
      "semantics": {
        "definition": "Communications exchanged with a customer.",
        "tags": ["communication", "interaction"]
      }
    },
    {
      "key": "customer-feature-usage",
      "sourceEntityTypeKey": "customer",
      "name": "Feature Usage",
      "protected": true,
      "targetRules": [
        { "targetEntityTypeKey": "feature-usage-event", "cardinalityOverride": "ONE_TO_MANY", "inverseName": "Customer" }
      ],
      "semantics": {
        "definition": "Feature usage events tracking how the customer uses the product.",
        "tags": ["engagement", "product-analytics"]
      }
    },
    {
      "key": "subscription-feature-usage",
      "sourceEntityTypeKey": "subscription",
      "name": "Feature Usage",
      "protected": true,
      "targetRules": [
        { "targetEntityTypeKey": "feature-usage-event", "cardinalityOverride": "ONE_TO_MANY", "inverseName": "Subscription" }
      ],
      "semantics": {
        "definition": "Feature usage events associated with a specific subscription.",
        "tags": ["usage", "subscription"]
      }
    }
  ]
}
