{
  "manifestVersion": "1.0",
  "key": "dtc-ecommerce",
  "name": "DTC E-commerce",
  "description": "Lifecycle template for direct-to-consumer e-commerce businesses. Traces the full customer journey from acquisition channel through orders, support, and billing to retention or churn.",
  "entityTypes": [
    { "$ref": "models/customer" },
    { "$ref": "models/communication" },
    { "$ref": "models/support-ticket" },
    {
      "key": "order",
      "displayName": { "singular": "Order", "plural": "Orders" },
      "semanticGroup": "TRANSACTION",
      "lifecycleDomain": "BILLING",
      "identifierKey": "order-number",
      "icon": { "type": "SHOPPING_CART", "colour": "EMERALD" },
      "attributes": {
        "order-number": {
          "key": "TEXT",
          "label": "Order Number",
          "type": "string",
          "unique": true,
          "semantics": {
            "definition": "Unique order identifier from the e-commerce platform.",
            "classification": "IDENTIFIER",
            "tags": ["reference", "unique-key"]
          }
        },
        "total": {
          "key": "CURRENCY",
          "label": "Total",
          "type": "number",
          "format": "currency",
          "semantics": {
            "definition": "Total order amount including tax and shipping.",
            "classification": "QUANTITATIVE",
            "tags": ["revenue", "billing"]
          }
        },
        "status": {
          "key": "SELECT",
          "label": "Status",
          "type": "string",
          "options": {
            "enum": ["pending", "confirmed", "shipped", "delivered", "cancelled", "returned"],
            "default": "pending"
          },
          "semantics": {
            "definition": "Current fulfilment status of the order.",
            "classification": "CATEGORICAL",
            "tags": ["lifecycle", "fulfilment"]
          }
        },
        "order-date": {
          "key": "DATE",
          "label": "Order Date",
          "type": "string",
          "format": "date",
          "semantics": {
            "definition": "Date the order was placed.",
            "classification": "TEMPORAL",
            "tags": ["timeline", "purchase"]
          }
        },
        "payment-status": {
          "key": "SELECT",
          "label": "Payment Status",
          "type": "string",
          "options": {
            "enum": ["pending", "paid", "refunded", "failed"],
            "default": "pending"
          },
          "semantics": {
            "definition": "Current payment state for this order.",
            "classification": "CATEGORICAL",
            "tags": ["payment", "billing"]
          }
        }
      },
      "semantics": {
        "definition": "A customer purchase order. The core revenue event in the e-commerce lifecycle, linking customers to products and payments.",
        "tags": ["purchase", "transaction", "ecommerce", "revenue"]
      }
    },
    {
      "key": "product",
      "displayName": { "singular": "Product", "plural": "Products" },
      "semanticGroup": "PRODUCT",
      "lifecycleDomain": "USAGE",
      "identifierKey": "name",
      "icon": { "type": "PACKAGE", "colour": "AMBER" },
      "attributes": {
        "name": {
          "key": "TEXT",
          "label": "Name",
          "type": "string",
          "semantics": {
            "definition": "Product name as displayed to customers.",
            "classification": "IDENTIFIER",
            "tags": ["display-name", "catalogue"]
          }
        },
        "sku": {
          "key": "TEXT",
          "label": "SKU",
          "type": "string",
          "unique": true,
          "semantics": {
            "definition": "Stock keeping unit for inventory tracking.",
            "classification": "IDENTIFIER",
            "tags": ["inventory", "unique-key"]
          }
        },
        "price": {
          "key": "CURRENCY",
          "label": "Price",
          "type": "number",
          "format": "currency",
          "semantics": {
            "definition": "Retail selling price.",
            "classification": "QUANTITATIVE",
            "tags": ["pricing", "revenue"]
          }
        },
        "category": {
          "key": "SELECT",
          "label": "Category",
          "type": "string",
          "options": {
            "enum": ["apparel", "electronics", "home", "beauty", "food", "accessories", "other"]
          },
          "semantics": {
            "definition": "Product category for organisation and reporting.",
            "classification": "CATEGORICAL",
            "tags": ["catalogue", "classification"]
          }
        }
      },
      "semantics": {
        "definition": "A sellable item in the store catalogue. Products are what customers purchase via orders.",
        "tags": ["catalogue", "inventory", "ecommerce"]
      }
    },
    {
      "key": "acquisition-source",
      "displayName": { "singular": "Acquisition Source", "plural": "Acquisition Sources" },
      "semanticGroup": "OPERATIONAL",
      "lifecycleDomain": "ACQUISITION",
      "identifierKey": "name",
      "icon": { "type": "MEGAPHONE", "colour": "VIOLET" },
      "attributes": {
        "name": {
          "key": "TEXT",
          "label": "Name",
          "type": "string",
          "semantics": {
            "definition": "Name of the acquisition channel or campaign.",
            "classification": "IDENTIFIER",
            "tags": ["display-name", "marketing"]
          }
        },
        "type": {
          "key": "SELECT",
          "label": "Type",
          "type": "string",
          "options": {
            "enum": ["paid-search", "paid-social", "organic", "email", "referral", "affiliate", "direct"]
          },
          "semantics": {
            "definition": "Category of acquisition channel.",
            "classification": "CATEGORICAL",
            "tags": ["marketing", "channel-type"]
          }
        },
        "spend": {
          "key": "CURRENCY",
          "label": "Spend",
          "type": "number",
          "format": "currency",
          "semantics": {
            "definition": "Total spend on this channel or campaign.",
            "classification": "QUANTITATIVE",
            "tags": ["marketing-spend", "budget"]
          }
        },
        "active": {
          "key": "CHECKBOX",
          "label": "Active",
          "type": "boolean",
          "semantics": {
            "definition": "Whether this channel or campaign is currently running.",
            "classification": "CATEGORICAL",
            "tags": ["status"]
          }
        }
      },
      "semantics": {
        "definition": "A marketing channel or campaign that brings customers to the business. Used for attribution and channel quality analysis.",
        "tags": ["marketing", "acquisition", "attribution"]
      }
    },
    {
      "key": "billing-event",
      "displayName": { "singular": "Billing Event", "plural": "Billing Events" },
      "semanticGroup": "FINANCIAL",
      "lifecycleDomain": "BILLING",
      "identifierKey": "description",
      "icon": { "type": "CREDIT_CARD", "colour": "EMERALD" },
      "attributes": {
        "description": {
          "key": "TEXT",
          "label": "Description",
          "type": "string",
          "semantics": {
            "definition": "Description of the billing event.",
            "classification": "IDENTIFIER",
            "tags": ["display-name"]
          }
        },
        "type": {
          "key": "SELECT",
          "label": "Type",
          "type": "string",
          "options": {
            "enum": ["charge", "refund", "credit", "adjustment", "payout"]
          },
          "semantics": {
            "definition": "The type of billing event.",
            "classification": "CATEGORICAL",
            "tags": ["billing", "classification"]
          }
        },
        "amount": {
          "key": "CURRENCY",
          "label": "Amount",
          "type": "number",
          "format": "currency",
          "semantics": {
            "definition": "Monetary value of this billing event.",
            "classification": "QUANTITATIVE",
            "tags": ["financial", "revenue"]
          }
        },
        "date": {
          "key": "DATE",
          "label": "Date",
          "type": "string",
          "format": "date",
          "semantics": {
            "definition": "Date the billing event occurred.",
            "classification": "TEMPORAL",
            "tags": ["timeline", "billing"]
          }
        }
      },
      "semantics": {
        "definition": "A financial event in the customer's billing lifecycle — charges, refunds, credits, or adjustments.",
        "tags": ["billing", "finance", "revenue"]
      }
    },
    {
      "key": "churn-event",
      "displayName": { "singular": "Churn Event", "plural": "Churn Events" },
      "semanticGroup": "FINANCIAL",
      "lifecycleDomain": "RETENTION",
      "identifierKey": "reason",
      "icon": { "type": "USER_MINUS", "colour": "ROSE" },
      "attributes": {
        "reason": {
          "key": "SELECT",
          "label": "Reason",
          "type": "string",
          "options": {
            "enum": ["price", "competitor", "no-longer-needed", "poor-experience", "product-issue", "unknown"]
          },
          "semantics": {
            "definition": "The stated or inferred reason for churning.",
            "classification": "CATEGORICAL",
            "tags": ["churn-reason", "analysis"]
          }
        },
        "date": {
          "key": "DATE",
          "label": "Date",
          "type": "string",
          "format": "date",
          "required": true,
          "semantics": {
            "definition": "Date the churn event occurred.",
            "classification": "TEMPORAL",
            "tags": ["timeline", "churn"]
          }
        },
        "type": {
          "key": "SELECT",
          "label": "Type",
          "type": "string",
          "options": {
            "enum": ["voluntary", "involuntary"],
            "default": "voluntary"
          },
          "semantics": {
            "definition": "Whether the customer chose to leave (voluntary) or was lost due to payment failure etc. (involuntary).",
            "classification": "CATEGORICAL",
            "tags": ["churn-type", "classification"]
          }
        },
        "notes": {
          "key": "TEXT",
          "label": "Notes",
          "type": "string",
          "semantics": {
            "definition": "Additional context about the churn event.",
            "classification": "FREETEXT",
            "tags": ["context"]
          }
        }
      },
      "semantics": {
        "definition": "Records when and why a customer relationship ended. The terminal lifecycle event, essential for churn analysis and retrospective tracing.",
        "tags": ["churn", "retention", "lifecycle"]
      }
    }
  ],
  "relationships": [
    {
      "key": "customer-orders",
      "sourceEntityTypeKey": "customer",
      "name": "Orders",
      "protected": true,
      "targetRules": [
        { "targetEntityTypeKey": "order", "cardinalityOverride": "ONE_TO_MANY", "inverseName": "Customer" }
      ],
      "semantics": {
        "definition": "A customer places orders to purchase products.",
        "tags": ["purchase", "revenue"]
      }
    },
    {
      "key": "customer-support-tickets",
      "sourceEntityTypeKey": "customer",
      "name": "Support Tickets",
      "protected": true,
      "targetRules": [
        { "targetEntityTypeKey": "support-ticket", "cardinalityOverride": "ONE_TO_MANY", "inverseName": "Customer" }
      ],
      "semantics": {
        "definition": "A customer files support tickets for issues or questions.",
        "tags": ["support", "service"]
      }
    },
    {
      "key": "customer-acquisition-source",
      "sourceEntityTypeKey": "customer",
      "name": "Acquisition Source",
      "protected": true,
      "targetRules": [
        { "targetEntityTypeKey": "acquisition-source", "cardinalityOverride": "MANY_TO_ONE", "inverseName": "Customers" }
      ],
      "semantics": {
        "definition": "The acquisition channel through which the customer was first converted.",
        "tags": ["attribution", "marketing"]
      }
    },
    {
      "key": "customer-billing-events",
      "sourceEntityTypeKey": "customer",
      "name": "Billing Events",
      "protected": true,
      "targetRules": [
        { "targetEntityTypeKey": "billing-event", "cardinalityOverride": "ONE_TO_MANY", "inverseName": "Customer" }
      ],
      "semantics": {
        "definition": "Billing events associated with a customer's account.",
        "tags": ["billing", "financial"]
      }
    },
    {
      "key": "customer-churn-events",
      "sourceEntityTypeKey": "customer",
      "name": "Churn Events",
      "protected": true,
      "targetRules": [
        { "targetEntityTypeKey": "churn-event", "cardinalityOverride": "ONE_TO_MANY", "inverseName": "Customer" }
      ],
      "semantics": {
        "definition": "Churn events marking the end of a customer relationship.",
        "tags": ["churn", "retention"]
      }
    },
    {
      "key": "customer-communications",
      "sourceEntityTypeKey": "customer",
      "name": "Communications",
      "protected": true,
      "targetRules": [
        { "targetEntityTypeKey": "communication", "cardinalityOverride": "ONE_TO_MANY", "inverseName": "Customer" }
      ],
      "semantics": {
        "definition": "Communications exchanged with a customer.",
        "tags": ["communication", "interaction"]
      }
    },
    {
      "key": "order-products",
      "sourceEntityTypeKey": "order",
      "name": "Products",
      "protected": true,
      "targetRules": [
        { "targetEntityTypeKey": "product", "cardinalityOverride": "MANY_TO_MANY", "inverseName": "Orders" }
      ],
      "semantics": {
        "definition": "Products included in an order.",
        "tags": ["line-items", "catalogue"]
      }
    }
  ]
}
