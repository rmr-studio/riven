{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "bundle.schema.json",
  "title": "Bundle Manifest",
  "description": "Schema for bundle manifests. A bundle is a named collection of template keys that are installed together.",
  "type": "object",
  "required": ["manifestVersion", "key", "name", "templates"],
  "additionalProperties": false,
  "properties": {
    "manifestVersion": {
      "type": "string",
      "const": "1.0",
      "description": "Manifest format version. Must be '1.0'."
    },
    "key": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Unique identifier for this bundle."
    },
    "name": {
      "type": "string",
      "description": "Human-readable name for this bundle."
    },
    "description": {
      "type": "string",
      "description": "Optional description of the bundle's purpose."
    },
    "templates": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      },
      "minItems": 1,
      "description": "Array of template keys to install as part of this bundle."
    }
  }
}
