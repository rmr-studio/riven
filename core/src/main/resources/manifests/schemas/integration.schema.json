{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "integration.schema.json",
  "title": "Integration Manifest",
  "description": "Schema for integration manifests. An integration defines entity types for external data sources (HubSpot, Salesforce, etc.) with optional field mappings. Entity types are always inline (no $ref) and typically readonly.",
  "type": "object",
  "required": ["manifestVersion", "key", "name", "category", "entityTypes"],
  "additionalProperties": false,
  "properties": {
    "manifestVersion": {
      "type": "string",
      "const": "1.0",
      "description": "Manifest format version. Must be '1.0'."
    },
    "key": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Unique identifier for this integration. Must match the integration_definitions.slug value. Derived from directory name."
    },
    "name": {
      "type": "string",
      "description": "Human-readable name for this integration."
    },
    "description": {
      "type": "string",
      "description": "Optional description of the integration's purpose."
    },
    "category": {
      "type": "string",
      "enum": ["CRM", "PAYMENTS", "SUPPORT", "EMAIL", "PROJECT_MANAGEMENT", "COMMUNICATION", "PRODUCT_ANALYTICS", "OTHER"],
      "description": "Integration category for catalog grouping. Must match IntegrationCategory enum."
    },
    "nangoProviderKey": {
      "type": "string",
      "description": "Nango provider config key for OAuth. Empty string means the integration is not yet connectable (coming soon)."
    },
    "iconUrl": {
      "type": "string",
      "description": "Relative path to the integration icon asset (e.g., '/integrations/hubspot.svg')."
    },
    "entityTypes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/integrationEntityType"
      },
      "description": "Array of inline entity type definitions for this integration. Integration entity types do not use $ref."
    },
    "relationships": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/relationship"
      },
      "description": "Optional array of relationship definitions between entity types in this integration."
    },
    "fieldMappings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fieldMapping"
      },
      "description": "Optional array of field mapping entries that map external provider fields to entity type attributes."
    },
    "syncModels": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "description": "Entity type key this Nango model maps to."
      },
      "description": "Maps Nango sync model names (e.g. 'contacts') to entity type keys (e.g. 'hubspot-contact'). Required for sync webhook dispatch to resolve the correct entity type."
    }
  },
  "$defs": {
    "integrationEntityType": {
      "type": "object",
      "required": ["key", "name", "displayName", "attributes"],
      "additionalProperties": false,
      "description": "An inline entity type definition for an integration. Typically has readonly: true.",
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "displayName": {
          "type": "object",
          "required": ["singular", "plural"],
          "additionalProperties": false,
          "properties": {
            "singular": { "type": "string" },
            "plural": { "type": "string" }
          }
        },
        "icon": {
          "$ref": "#/$defs/icon"
        },
        "semanticGroup": {
          "type": "string",
          "enum": [
            "CUSTOMER",
            "PRODUCT",
            "TRANSACTION",
            "COMMUNICATION",
            "SUPPORT",
            "FINANCIAL",
            "OPERATIONAL",
            "CUSTOM",
            "UNCATEGORIZED"
          ]
        },
        "lifecycleDomain": {
          "type": "string",
          "description": "Optional lifecycle domain for projection routing. Defaults to UNCATEGORIZED if omitted."
        },
        "identifierKey": {
          "type": "string"
        },
        "readonly": {
          "type": "boolean",
          "description": "Whether this entity type is read-only. Typically true for integration entities."
        },
        "attributes": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/attribute"
          }
        },
        "semantics": {
          "$ref": "#/$defs/entityTypeSemantics"
        }
      }
    },
    "relationship": {
      "type": "object",
      "required": ["key", "sourceEntityTypeKey", "name"],
      "additionalProperties": false,
      "description": "A relationship definition. Use shorthand format (targetEntityTypeKey + cardinality) for single-target relationships, or full format (targetRules array) for polymorphic/multi-target relationships.",
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "sourceEntityTypeKey": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "icon": {
          "$ref": "#/$defs/icon"
        },
        "cardinality": {
          "type": "string",
          "enum": ["ONE_TO_ONE", "ONE_TO_MANY", "MANY_TO_ONE", "MANY_TO_MANY"]
        },
        "targetEntityTypeKey": {
          "type": "string"
        },
        "protected": {
          "type": "boolean"
        },
        "targetRules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/targetRule"
          }
        },
        "semantics": {
          "$ref": "#/$defs/relationshipSemantics"
        }
      },
      "oneOf": [
        {
          "required": ["cardinality", "targetEntityTypeKey"],
          "not": { "required": ["targetRules"] }
        },
        {
          "required": ["targetRules"],
          "not": {
            "anyOf": [
              { "required": ["cardinality"] },
              { "required": ["targetEntityTypeKey"] }
            ]
          }
        }
      ]
    },
    "targetRule": {
      "type": "object",
      "required": ["targetEntityTypeKey"],
      "additionalProperties": false,
      "properties": {
        "targetEntityTypeKey": {
          "type": "string"
        },
        "cardinalityOverride": {
          "type": "string",
          "enum": ["ONE_TO_ONE", "ONE_TO_MANY", "MANY_TO_ONE", "MANY_TO_MANY"]
        },
        "inverseVisible": {
          "type": "boolean"
        },
        "inverseName": {
          "type": "string"
        }
      }
    },
    "fieldMapping": {
      "type": "object",
      "required": ["entityTypeKey", "mappings"],
      "additionalProperties": false,
      "description": "Maps external provider field names to entity type attribute keys.",
      "properties": {
        "entityTypeKey": {
          "type": "string",
          "description": "Key of the entity type these mappings apply to."
        },
        "mappings": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["source"],
            "properties": {
              "source": { "type": "string", "description": "Source field path from the external provider." },
              "transform": {
                "type": "object",
                "description": "Optional transformation configuration with discriminated type.",
                "required": ["type"],
                "oneOf": [
                  {
                    "properties": {
                      "type": { "const": "direct" }
                    },
                    "additionalProperties": false
                  },
                  {
                    "properties": {
                      "type": { "const": "type_coercion" },
                      "targetType": { "type": "string", "enum": ["number", "boolean", "date", "datetime", "string"] }
                    },
                    "required": ["type", "targetType"],
                    "additionalProperties": false
                  },
                  {
                    "properties": {
                      "type": { "const": "default_value" },
                      "value": {}
                    },
                    "required": ["type", "value"],
                    "additionalProperties": false
                  },
                  {
                    "properties": {
                      "type": { "const": "json_path_extraction" },
                      "path": { "type": "string" }
                    },
                    "required": ["type", "path"],
                    "additionalProperties": false
                  }
                ]
              }
            },
            "additionalProperties": false
          },
          "description": "Map of target attribute key to mapping configuration. Each value must have a 'source' field."
        }
      }
    },
    "attribute": {
      "type": "object",
      "required": ["key", "type"],
      "additionalProperties": false,
      "properties": {
        "key": {
          "type": "string",
          "enum": [
            "TEXT",
            "OBJECT",
            "NUMBER",
            "CHECKBOX",
            "DATE",
            "DATETIME",
            "RATING",
            "PHONE",
            "EMAIL",
            "URL",
            "CURRENCY",
            "PERCENTAGE",
            "SELECT",
            "MULTI_SELECT",
            "FILE_ATTACHMENT",
            "LOCATION"
          ]
        },
        "label": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["string", "number", "boolean", "object", "array", "null"]
        },
        "format": {
          "type": "string",
          "enum": [
            "date",
            "date-time",
            "email",
            "phone-number",
            "currency",
            "uri",
            "percentage"
          ]
        },
        "required": { "type": "boolean" },
        "unique": { "type": "boolean" },
        "protected": { "type": "boolean" },
        "icon": { "$ref": "#/$defs/icon" },
        "options": { "$ref": "#/$defs/attributeOptions" },
        "semantics": { "$ref": "#/$defs/attributeSemantics" }
      }
    },
    "icon": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string" },
        "colour": { "type": "string" }
      }
    },
    "attributeOptions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default": {},
        "regex": { "type": "string" },
        "enum": {
          "type": "array",
          "items": { "type": "string" }
        },
        "enumSorting": { "type": "string" },
        "minLength": { "type": "integer" },
        "maxLength": { "type": "integer" },
        "minimum": { "type": "number" },
        "maximum": { "type": "number" }
      }
    },
    "entityTypeSemantics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "definition": { "type": "string" },
        "classification": {
          "type": "string",
          "enum": [
            "IDENTIFIER",
            "CATEGORICAL",
            "QUANTITATIVE",
            "TEMPORAL",
            "FREETEXT",
            "RELATIONAL_REFERENCE"
          ]
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "attributeSemantics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "definition": { "type": "string" },
        "classification": {
          "type": "string",
          "enum": [
            "IDENTIFIER",
            "CATEGORICAL",
            "QUANTITATIVE",
            "TEMPORAL",
            "FREETEXT",
            "RELATIONAL_REFERENCE"
          ]
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "relationshipSemantics": {
      "type": "object",
      "additionalProperties": false,
      "description": "Semantic metadata for relationships. No 'classification' field -- classification is only meaningful for attributes.",
      "properties": {
        "definition": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
