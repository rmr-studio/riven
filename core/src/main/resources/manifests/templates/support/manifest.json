{
  "manifestVersion": "1.0",
  "key": "support",
  "name": "Support",
  "description": "Customer support ticket management for tracking issues, questions, and feedback through resolution.",
  "entityTypes": [
    {
      "$ref": "models/support-ticket"
    }
  ],
  "relationships": [
    {
      "key": "customer-support-tickets",
      "sourceEntityTypeKey": "customer",
      "name": "Support Tickets",
      "allowPolymorphic": false,
      "protected": false,
      "targetRules": [
        {
          "targetEntityTypeKey": "support-ticket",
          "cardinalityOverride": "ONE_TO_MANY",
          "inverseName": "Customer"
        }
      ],
      "semantics": {
        "definition": "A customer submits support tickets when they encounter issues, have questions, or want to request features.",
        "tags": ["support", "customer-service"]
      }
    }
  ]
}
