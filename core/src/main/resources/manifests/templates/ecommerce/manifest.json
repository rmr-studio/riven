{
  "manifestVersion": "1.0",
  "key": "ecommerce",
  "name": "E-commerce",
  "description": "E-commerce operations covering orders, products, returns, suppliers, and acquisition channel tracking for direct-to-consumer businesses.",
  "entityTypes": [
    {
      "key": "order",
      "name": "Order",
      "description": "A customer purchase order tracking items, payment, fulfilment, and delivery through to completion.",
      "displayName": {
        "singular": "Order",
        "plural": "Orders"
      },
      "semanticGroup": "TRANSACTION",
      "identifierKey": "order-number",
      "attributes": {
        "order-number": {
          "key": "TEXT",
          "label": "Order Number",
          "type": "string",
          "unique": true,
          "semantics": {
            "definition": "A unique identifier for this order, used for tracking, customer communication, and fulfilment.",
            "classification": "IDENTIFIER",
            "tags": ["reference", "unique-key"]
          }
        },
        "status": {
          "key": "SELECT",
          "label": "Status",
          "type": "string",
          "options": {
            "enum": ["pending", "confirmed", "processing", "shipped", "delivered", "cancelled"],
            "default": "pending"
          },
          "semantics": {
            "definition": "The current fulfilment state of the order.",
            "classification": "CATEGORICAL",
            "tags": ["lifecycle", "fulfilment"]
          }
        },
        "total": {
          "key": "CURRENCY",
          "label": "Total",
          "type": "number",
          "format": "currency",
          "semantics": {
            "definition": "The total amount charged for this order including subtotal, tax, and shipping.",
            "classification": "QUANTITATIVE",
            "tags": ["revenue", "billing"]
          }
        },
        "subtotal": {
          "key": "CURRENCY",
          "label": "Subtotal",
          "type": "number",
          "format": "currency",
          "semantics": {
            "definition": "The sum of all item prices before tax and shipping.",
            "classification": "QUANTITATIVE",
            "tags": ["revenue", "detail"]
          }
        },
        "tax": {
          "key": "CURRENCY",
          "label": "Tax",
          "type": "number",
          "format": "currency",
          "semantics": {
            "definition": "The total tax amount applied to this order.",
            "classification": "QUANTITATIVE",
            "tags": ["tax", "accounting"]
          }
        },
        "shipping-cost": {
          "key": "CURRENCY",
          "label": "Shipping Cost",
          "type": "number",
          "format": "currency",
          "semantics": {
            "definition": "The shipping charges for delivering this order to the customer.",
            "classification": "QUANTITATIVE",
            "tags": ["shipping", "logistics"]
          }
        },
        "order-date": {
          "key": "DATE",
          "label": "Order Date",
          "type": "string",
          "format": "date",
          "semantics": {
            "definition": "The date the order was placed by the customer.",
            "classification": "TEMPORAL",
            "tags": ["timeline", "purchase"]
          }
        },
        "fulfillment-date": {
          "key": "DATE",
          "label": "Fulfillment Date",
          "type": "string",
          "format": "date",
          "semantics": {
            "definition": "The date the order was fully shipped or delivered.",
            "classification": "TEMPORAL",
            "tags": ["fulfilment", "logistics"]
          }
        },
        "shipping-method": {
          "key": "SELECT",
          "label": "Shipping Method",
          "type": "string",
          "options": {
            "enum": ["standard", "express", "overnight", "pickup"]
          },
          "semantics": {
            "definition": "The delivery method selected for this order.",
            "classification": "CATEGORICAL",
            "tags": ["shipping", "logistics"]
          }
        },
        "payment-status": {
          "key": "SELECT",
          "label": "Payment Status",
          "type": "string",
          "options": {
            "enum": ["pending", "authorized", "captured", "refunded", "failed"],
            "default": "pending"
          },
          "semantics": {
            "definition": "The current state of payment processing for this order.",
            "classification": "CATEGORICAL",
            "tags": ["payment", "billing"]
          }
        }
      },
      "semantics": {
        "definition": "An order represents a customer's purchase transaction, tracking items, payment, and fulfilment from placement through delivery. It is the core revenue-generating event in the e-commerce lifecycle.",
        "tags": ["purchase", "transaction", "ecommerce", "revenue"]
      }
    },
    {
      "key": "product",
      "name": "Product",
      "description": "A physical or digital product available for sale in the store catalogue.",
      "displayName": {
        "singular": "Product",
        "plural": "Products"
      },
      "semanticGroup": "PRODUCT",
      "identifierKey": "sku",
      "attributes": {
        "sku": {
          "key": "TEXT",
          "label": "SKU",
          "type": "string",
          "unique": true,
          "semantics": {
            "definition": "The stock keeping unit, a unique product identifier used for inventory tracking and fulfilment.",
            "classification": "IDENTIFIER",
            "tags": ["inventory", "unique-key"]
          }
        },
        "name": {
          "key": "TEXT",
          "label": "Name",
          "type": "string",
          "semantics": {
            "definition": "The product name as displayed to customers.",
            "classification": "IDENTIFIER",
            "tags": ["display-name", "catalogue"]
          }
        },
        "category": {
          "key": "SELECT",
          "label": "Category",
          "type": "string",
          "options": {
            "enum": ["apparel", "electronics", "home", "beauty", "food", "accessories", "other"]
          },
          "semantics": {
            "definition": "The product category for catalogue organisation and reporting.",
            "classification": "CATEGORICAL",
            "tags": ["catalogue", "classification"]
          }
        },
        "price": {
          "key": "CURRENCY",
          "label": "Price",
          "type": "number",
          "format": "currency",
          "semantics": {
            "definition": "The retail selling price of the product.",
            "classification": "QUANTITATIVE",
            "tags": ["pricing", "revenue"]
          }
        },
        "cost": {
          "key": "CURRENCY",
          "label": "Cost",
          "type": "number",
          "format": "currency",
          "semantics": {
            "definition": "The cost of goods sold (COGS) for this product, used for margin calculations.",
            "classification": "QUANTITATIVE",
            "tags": ["cost", "margin"]
          }
        },
        "inventory-count": {
          "key": "NUMBER",
          "label": "Inventory Count",
          "type": "number",
          "semantics": {
            "definition": "The current number of units available in stock.",
            "classification": "QUANTITATIVE",
            "tags": ["inventory", "stock"]
          }
        },
        "status": {
          "key": "SELECT",
          "label": "Status",
          "type": "string",
          "options": {
            "enum": ["active", "discontinued", "out-of-stock", "draft"],
            "default": "active"
          },
          "semantics": {
            "definition": "The current availability status of the product in the catalogue.",
            "classification": "CATEGORICAL",
            "tags": ["lifecycle", "availability"]
          }
        },
        "brand": {
          "key": "TEXT",
          "label": "Brand",
          "type": "string",
          "semantics": {
            "definition": "The brand or manufacturer name of the product.",
            "classification": "CATEGORICAL",
            "tags": ["brand", "catalogue"]
          }
        },
        "weight": {
          "key": "NUMBER",
          "label": "Weight",
          "type": "number",
          "semantics": {
            "definition": "The product weight in kilograms, used for shipping cost calculations.",
            "classification": "QUANTITATIVE",
            "tags": ["shipping", "logistics"]
          }
        }
      },
      "semantics": {
        "definition": "A product is a sellable item in the store catalogue, with pricing, inventory, and supplier information. Products are the core commercial offering that customers purchase via orders.",
        "tags": ["catalogue", "inventory", "ecommerce", "merchandise"]
      }
    },
    {
      "key": "return",
      "name": "Return",
      "description": "A product return or exchange initiated by a customer, tracking the return process from request through resolution.",
      "displayName": {
        "singular": "Return",
        "plural": "Returns"
      },
      "semanticGroup": "TRANSACTION",
      "identifierKey": "return-number",
      "attributes": {
        "return-number": {
          "key": "TEXT",
          "label": "Return Number",
          "type": "string",
          "unique": true,
          "semantics": {
            "definition": "A unique identifier for this return request.",
            "classification": "IDENTIFIER",
            "tags": ["reference", "unique-key"]
          }
        },
        "reason": {
          "key": "SELECT",
          "label": "Reason",
          "type": "string",
          "options": {
            "enum": ["defective", "wrong-item", "not-as-described", "changed-mind", "sizing", "other"]
          },
          "semantics": {
            "definition": "The reason the customer is returning the product.",
            "classification": "CATEGORICAL",
            "tags": ["return-reason", "quality"]
          }
        },
        "status": {
          "key": "SELECT",
          "label": "Status",
          "type": "string",
          "options": {
            "enum": ["requested", "approved", "received", "refunded", "rejected"],
            "default": "requested"
          },
          "semantics": {
            "definition": "The current state of the return in its processing lifecycle.",
            "classification": "CATEGORICAL",
            "tags": ["lifecycle", "processing"]
          }
        },
        "refund-amount": {
          "key": "CURRENCY",
          "label": "Refund Amount",
          "type": "number",
          "format": "currency",
          "semantics": {
            "definition": "The monetary amount to be refunded to the customer.",
            "classification": "QUANTITATIVE",
            "tags": ["refund", "financial"]
          }
        },
        "return-date": {
          "key": "DATE",
          "label": "Return Date",
          "type": "string",
          "format": "date",
          "semantics": {
            "definition": "The date the return was initiated by the customer.",
            "classification": "TEMPORAL",
            "tags": ["timeline"]
          }
        },
        "resolution": {
          "key": "SELECT",
          "label": "Resolution",
          "type": "string",
          "options": {
            "enum": ["refund", "exchange", "store-credit", "rejected"]
          },
          "semantics": {
            "definition": "How the return was resolved.",
            "classification": "CATEGORICAL",
            "tags": ["resolution", "outcome"]
          }
        },
        "restocking-fee": {
          "key": "CURRENCY",
          "label": "Restocking Fee",
          "type": "number",
          "format": "currency",
          "semantics": {
            "definition": "Any restocking fee applied to the return, reducing the refund amount.",
            "classification": "QUANTITATIVE",
            "tags": ["fee", "financial"]
          }
        },
        "notes": {
          "key": "TEXT",
          "label": "Notes",
          "type": "string",
          "semantics": {
            "definition": "Additional notes about the return, such as condition of items or special handling instructions.",
            "classification": "FREETEXT",
            "tags": ["context", "detail"]
          }
        }
      },
      "semantics": {
        "definition": "A return tracks the process of a customer sending back purchased products, from initial request through inspection, resolution, and refund. Returns are a key indicator of product quality and customer satisfaction.",
        "tags": ["returns", "refund", "customer-satisfaction", "ecommerce"]
      }
    },
    {
      "key": "supplier",
      "name": "Supplier",
      "description": "A vendor or manufacturer that provides products for sale, with contact, terms, and performance details.",
      "displayName": {
        "singular": "Supplier",
        "plural": "Suppliers"
      },
      "semanticGroup": "OPERATIONAL",
      "identifierKey": "name",
      "attributes": {
        "name": {
          "key": "TEXT",
          "label": "Name",
          "type": "string",
          "semantics": {
            "definition": "The name of the supplier company.",
            "classification": "IDENTIFIER",
            "tags": ["display-name", "vendor"]
          }
        },
        "contact-email": {
          "key": "EMAIL",
          "label": "Contact Email",
          "type": "string",
          "format": "email",
          "semantics": {
            "definition": "The primary email address for contacting this supplier.",
            "classification": "IDENTIFIER",
            "tags": ["contact", "communication"]
          }
        },
        "lead-time-days": {
          "key": "NUMBER",
          "label": "Lead Time (Days)",
          "type": "number",
          "semantics": {
            "definition": "The typical number of days between placing an order and receiving goods from this supplier.",
            "classification": "QUANTITATIVE",
            "tags": ["logistics", "planning"]
          }
        },
        "payment-terms": {
          "key": "SELECT",
          "label": "Payment Terms",
          "type": "string",
          "options": {
            "enum": ["net-15", "net-30", "net-60", "prepaid", "cod"]
          },
          "semantics": {
            "definition": "The agreed payment terms with this supplier.",
            "classification": "CATEGORICAL",
            "tags": ["billing", "terms"]
          }
        },
        "rating": {
          "key": "RATING",
          "label": "Rating",
          "type": "number",
          "options": {
            "minimum": 1,
            "maximum": 5
          },
          "semantics": {
            "definition": "An internal quality rating for this supplier based on reliability, quality, and service.",
            "classification": "QUANTITATIVE",
            "tags": ["quality", "performance"]
          }
        },
        "status": {
          "key": "SELECT",
          "label": "Status",
          "type": "string",
          "options": {
            "enum": ["active", "inactive", "on-hold", "pending-review"],
            "default": "active"
          },
          "semantics": {
            "definition": "The current status of the supplier relationship.",
            "classification": "CATEGORICAL",
            "tags": ["lifecycle", "vendor-management"]
          }
        },
        "country": {
          "key": "TEXT",
          "label": "Country",
          "type": "string",
          "semantics": {
            "definition": "The country where the supplier is based.",
            "classification": "CATEGORICAL",
            "tags": ["geography", "logistics"]
          }
        },
        "minimum-order": {
          "key": "CURRENCY",
          "label": "Minimum Order",
          "type": "number",
          "format": "currency",
          "semantics": {
            "definition": "The minimum order value required by this supplier.",
            "classification": "QUANTITATIVE",
            "tags": ["terms", "procurement"]
          }
        }
      },
      "semantics": {
        "definition": "A supplier is a vendor or manufacturer that provides products for the store's catalogue. The supplier entity tracks commercial terms, performance, and contact information for procurement operations.",
        "tags": ["procurement", "vendor", "supply-chain", "operations"]
      }
    },
    {
      "key": "acquisition-channel",
      "name": "Acquisition Channel",
      "description": "A marketing or acquisition channel used to attract customers, tracking spend, conversions, and return on investment.",
      "displayName": {
        "singular": "Acquisition Channel",
        "plural": "Acquisition Channels"
      },
      "semanticGroup": "OPERATIONAL",
      "identifierKey": "name",
      "attributes": {
        "name": {
          "key": "TEXT",
          "label": "Name",
          "type": "string",
          "semantics": {
            "definition": "The name of the acquisition channel or campaign.",
            "classification": "IDENTIFIER",
            "tags": ["display-name", "marketing"]
          }
        },
        "type": {
          "key": "SELECT",
          "label": "Type",
          "type": "string",
          "options": {
            "enum": ["paid-search", "paid-social", "organic", "email", "referral", "affiliate", "direct"]
          },
          "semantics": {
            "definition": "The category of acquisition channel.",
            "classification": "CATEGORICAL",
            "tags": ["marketing", "channel-type"]
          }
        },
        "cost": {
          "key": "CURRENCY",
          "label": "Cost",
          "type": "number",
          "format": "currency",
          "semantics": {
            "definition": "The total spend on this channel or campaign.",
            "classification": "QUANTITATIVE",
            "tags": ["marketing-spend", "budget"]
          }
        },
        "conversions": {
          "key": "NUMBER",
          "label": "Conversions",
          "type": "number",
          "semantics": {
            "definition": "The number of customers acquired through this channel.",
            "classification": "QUANTITATIVE",
            "tags": ["performance", "acquisition"]
          }
        },
        "revenue-attributed": {
          "key": "CURRENCY",
          "label": "Revenue Attributed",
          "type": "number",
          "format": "currency",
          "semantics": {
            "definition": "The total revenue attributed to customers acquired through this channel.",
            "classification": "QUANTITATIVE",
            "tags": ["revenue", "attribution"]
          }
        },
        "roi": {
          "key": "PERCENTAGE",
          "label": "ROI",
          "type": "number",
          "format": "percentage",
          "semantics": {
            "definition": "The return on investment for this channel, calculated as (revenue - cost) / cost.",
            "classification": "QUANTITATIVE",
            "tags": ["performance", "efficiency"]
          }
        },
        "active": {
          "key": "CHECKBOX",
          "label": "Active",
          "type": "boolean",
          "semantics": {
            "definition": "Whether this channel or campaign is currently running.",
            "classification": "CATEGORICAL",
            "tags": ["status", "lifecycle"]
          }
        },
        "campaign-name": {
          "key": "TEXT",
          "label": "Campaign Name",
          "type": "string",
          "semantics": {
            "definition": "The specific campaign name within this channel, if applicable.",
            "classification": "IDENTIFIER",
            "tags": ["marketing", "campaign"]
          }
        }
      },
      "semantics": {
        "definition": "An acquisition channel represents a marketing source or campaign used to attract new customers, tracking investment, performance, and return on marketing spend.",
        "tags": ["marketing", "acquisition", "performance", "growth"]
      }
    }
  ],
  "relationships": [
    {
      "key": "customer-orders",
      "sourceEntityTypeKey": "customer",
      "name": "Orders",
      "allowPolymorphic": false,
      "protected": false,
      "targetRules": [
        {
          "targetEntityTypeKey": "order",
          "cardinalityOverride": "ONE_TO_MANY",
          "inverseName": "Customer"
        }
      ],
      "semantics": {
        "definition": "A customer places orders to purchase products. This relationship links buying behaviour to individual customer records.",
        "tags": ["purchase", "revenue"]
      }
    },
    {
      "key": "order-products",
      "sourceEntityTypeKey": "order",
      "name": "Products",
      "allowPolymorphic": false,
      "protected": false,
      "targetRules": [
        {
          "targetEntityTypeKey": "product",
          "cardinalityOverride": "MANY_TO_MANY",
          "inverseName": "Orders"
        }
      ],
      "semantics": {
        "definition": "An order contains one or more products that the customer has purchased.",
        "tags": ["line-items", "catalogue"]
      }
    },
    {
      "key": "customer-returns",
      "sourceEntityTypeKey": "customer",
      "name": "Returns",
      "allowPolymorphic": false,
      "protected": false,
      "targetRules": [
        {
          "targetEntityTypeKey": "return",
          "cardinalityOverride": "ONE_TO_MANY",
          "inverseName": "Customer"
        }
      ],
      "semantics": {
        "definition": "A customer initiates returns for products they wish to send back or exchange.",
        "tags": ["returns", "customer-satisfaction"]
      }
    },
    {
      "key": "order-returns",
      "sourceEntityTypeKey": "order",
      "name": "Returns",
      "allowPolymorphic": false,
      "protected": false,
      "targetRules": [
        {
          "targetEntityTypeKey": "return",
          "cardinalityOverride": "ONE_TO_MANY",
          "inverseName": "Original Order"
        }
      ],
      "semantics": {
        "definition": "An order may have one or more returns associated with it when customers return purchased items.",
        "tags": ["returns", "fulfilment"]
      }
    },
    {
      "key": "product-supplier",
      "sourceEntityTypeKey": "product",
      "name": "Suppliers",
      "allowPolymorphic": false,
      "protected": false,
      "targetRules": [
        {
          "targetEntityTypeKey": "supplier",
          "cardinalityOverride": "MANY_TO_MANY",
          "inverseName": "Products"
        }
      ],
      "semantics": {
        "definition": "A product is sourced from one or more suppliers who manufacture or distribute it.",
        "tags": ["supply-chain", "procurement"]
      }
    },
    {
      "key": "customer-acquisition-channel",
      "sourceEntityTypeKey": "customer",
      "name": "Acquisition Channel",
      "allowPolymorphic": false,
      "protected": false,
      "targetRules": [
        {
          "targetEntityTypeKey": "acquisition-channel",
          "cardinalityOverride": "MANY_TO_ONE",
          "inverseName": "Customers"
        }
      ],
      "semantics": {
        "definition": "A customer is attributed to the acquisition channel through which they were first converted.",
        "tags": ["attribution", "marketing"]
      }
    }
  ]
}
