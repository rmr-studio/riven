{
  "manifestVersion": "1.0",
  "key": "communication",
  "name": "Communication",
  "description": "A logged interaction with a client, capturing context, outcome, and follow-up actions.",
  "displayName": {
    "singular": "Communication",
    "plural": "Communications"
  },
  "semanticGroup": "COMMUNICATION",
  "identifierKey": "subject",
  "attributes": {
    "subject": {
      "key": "TEXT",
      "label": "Subject",
      "type": "string",
      "semantics": {
        "definition": "The subject or topic of the communication.",
        "classification": "IDENTIFIER",
        "tags": ["display-name", "topic"]
      }
    },
    "type": {
      "key": "SELECT",
      "label": "Type",
      "type": "string",
      "options": {
        "enum": ["meeting", "call", "email", "presentation", "workshop"]
      },
      "semantics": {
        "definition": "The format or medium of this communication.",
        "classification": "CATEGORICAL",
        "tags": ["format", "channel"]
      }
    },
    "direction": {
      "key": "SELECT",
      "label": "Direction",
      "type": "string",
      "options": {
        "enum": ["inbound", "outbound"]
      },
      "semantics": {
        "definition": "Whether this communication was initiated by the client or by the team.",
        "classification": "CATEGORICAL",
        "tags": ["direction", "initiative"]
      }
    },
    "date": {
      "key": "DATE",
      "label": "Date",
      "type": "string",
      "format": "date",
      "semantics": {
        "definition": "The date of the communication.",
        "classification": "TEMPORAL",
        "tags": ["timeline"]
      }
    },
    "summary": {
      "key": "TEXT",
      "label": "Summary",
      "type": "string",
      "semantics": {
        "definition": "A summary of what was discussed or communicated.",
        "classification": "FREETEXT",
        "tags": ["notes", "context"]
      }
    },
    "follow-up-date": {
      "key": "DATE",
      "label": "Follow-up Date",
      "type": "string",
      "format": "date",
      "semantics": {
        "definition": "The date by which a follow-up action is expected.",
        "classification": "TEMPORAL",
        "tags": ["action-item", "deadline"]
      }
    },
    "outcome": {
      "key": "SELECT",
      "label": "Outcome",
      "type": "string",
      "options": {
        "enum": ["positive", "neutral", "needs-action", "escalated"]
      },
      "semantics": {
        "definition": "The outcome or disposition of this communication.",
        "classification": "CATEGORICAL",
        "tags": ["result", "disposition"]
      }
    },
    "channel": {
      "key": "SELECT",
      "label": "Channel",
      "type": "string",
      "options": {
        "enum": ["phone", "video", "in-person", "email", "chat"]
      },
      "semantics": {
        "definition": "The specific channel used for this communication.",
        "classification": "CATEGORICAL",
        "tags": ["channel", "medium"]
      }
    }
  },
  "semantics": {
    "definition": "A communication logs a client interaction, capturing what was discussed, the outcome, and any required follow-ups. It provides the audit trail for client relationship management and ensures continuity across team members.",
    "tags": ["client-relations", "interaction", "crm", "communication"]
  }
}
