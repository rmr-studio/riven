        },
        "topic": {
          "source": "topic",
          "transform": { "type": "direct" }
        },
        "purpose": {
          "source": "purpose",
          "transform": { "type": "direct" }
        },
        "is-private": {
          "source": "is_private",
          "transform": { "type": "direct" }
        },
        "member-count": {
          "source": "member_count",
          "transform": { "type": "type_coercion", "targetType": "number" }
        },
        "created": {
          "source": "created",
          "transform": { "type": "type_coercion", "targetType": "datetime" }
        }
      }
    },
    {
      "entityTypeKey": "slack-user",
      "mappings": {
        "display-name": {
          "source": "display_name",
          "transform": { "type": "direct" }
        },
        "real-name": {
          "source": "real_name",
          "transform": { "type": "direct" }
        },
        "email": {
          "source": "email",
          "transform": { "type": "direct" }
        },
        "title": {
          "source": "title",
          "transform": { "type": "direct" }
        },
        "status-text": {
          "source": "status_text",
          "transform": { "type": "direct" }
        }
      }
    }
  ],
  "relationships": []
